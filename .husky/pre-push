#!/usr/bin/env sh


## START - test branch name

### Check remote url and branch name convention
### This script tries to follow the rule of 'https://conventional-branch.github.io/#specification', but there may be bugs
### This rule is not a strict `MUST` follow rule, but following conventions always good.

TARGET_REPO_PATTERN='(^|[:/])Tektonian/tektonian-python(\.git)?$'
DESCRIPTION_RULE='[a-z0-9]+([.-][a-z0-9]+)*'
BRANCH_RULE="^(main|master|develop|((feat|bugfix|hotfix|release|chore)/${DESCRIPTION_RULE}))$"
ZERO_HASH='0000000000000000000000000000000000000000'

remote_name="$1"
remote_url="$2"

is_valid_branch_name() {
  printf '%s\n' "$1" | grep -Eq "$BRANCH_RULE"
}

show_error() {
  branch_name="$1"

  echo "Branch name rule violation: $branch_name"
  echo "Remote: $remote_name ($remote_url)"
  echo "Allowed pattern:"
  echo "  - main"
  echo "  - master"
  echo "  - develop"
  echo "  - <type>/<description>"
  echo "  - <type>/<issue>-<description>"
  echo "Allowed types: feat, bugfix hotfix, release, chore"
  echo "Description rule: lowercase letters/numbers with single '-' or '.' separators only"
  echo "Examples: feat/login-form, feat/issue-123-new-login, release/v1.2.0"
  echo "Wrong Examples: feat/new--login, release/v1..2.0, feat/new_login"
  echo "This script tries to follow the rule of 'https://conventional-branch.github.io/#specification'"
  echo "This rule is not a strict 'MUST' follow rule, but following conventions always good."
  echo "If you want to disable this message set env-var HUSKY to 0 with 'export HUSKY=0'"

}

if ! printf '%s\n' "$remote_url" | grep -Eq "$TARGET_REPO_PATTERN"; then
  exit 0
fi

checked_branch=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$remote_ref" ] && continue

  case "$local_ref" in
    "(delete)")
      continue
      ;;
  esac

  if [ "$local_sha" = "$ZERO_HASH" ]; then
    continue
  fi

  case "$remote_ref" in
    refs/heads/*)
      branch_name=${remote_ref#refs/heads/}
      checked_branch=1

      if ! is_valid_branch_name "$branch_name"; then
        show_error "$branch_name"
        exit 1
      fi
      ;;
  esac
done

if [ "$checked_branch" -eq 0 ]; then
  exit 0
fi

## END - test branch name
