                                )
                                {
                                    rel material:binding = </allegro_left/Materials/white>
                                }
                            }
                        }
                    }
                }
            }

            over "th_base"
            {
                over "tn__link_120_left_VK" (
                    prepend apiSchemas = ["MaterialBindingAPI"]
                )
                {
                    rel material:binding = </allegro_left/Materials/black>
                }

                over "th_proximal"
                {
                    over "tn__link_130_nC" (
                        prepend apiSchemas = ["MaterialBindingAPI"]
                    )
                    {
                        rel material:binding = </allegro_left/Materials/black>
                    }

                    over "th_medial"
                    {
                        over "tn__link_140_nC" (
                            prepend apiSchemas = ["MaterialBindingAPI"]
                        )
                        {
                            rel material:binding = </allegro_left/Materials/black>
